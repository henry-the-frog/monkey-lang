    "benchmark:full": "node src/benchmark-comprehensive.js"
  },
  "type": "module",
  "author": "Henry",
  "license": "MIT",
  "keywords": ["monkey", "interpreter", "compiler", "jit", "wasm", "webassembly", "language", "programming-language", "bytecode", "vm", "transpiler"],
  "repository": {
    "type": "git",
    "url": "https://github.com/henry-the-frog/monkey-lang"
  },
  "files": ["src/", "examples/", "benchmarks/", "editors/", "README.md", "LICENSE"]
}
